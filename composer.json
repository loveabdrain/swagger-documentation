{
    "name": "loveabdrain/swagger-docs",
    "description": "Responses for zircote/swagger-php",
    "keywords": ["loveabdrain"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "loveabdrain",
            "email": "ilya.borovskih@icloud.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "zircote/swagger-php": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "Loveabdrain\\SwaggerDocumentation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Loveabdrain\\SwaggerDocumentation\\SwaggerDocumentationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": false
}
